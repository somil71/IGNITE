{
  "version": 2,
  "builds": [
    {
      "src": "server/src/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/src/index.js"
    },
    {
      "source": "/(css|js|img|assets)/(.*)",
      "destination": "/client/$1/$2"
    },
    {
      "source": "/favicon.ico",
      "destination": "/client/favicon.ico"
    },
    {
      "source": "/(.*)",
      "destination": "/client/index.html"
    }
  ]
}

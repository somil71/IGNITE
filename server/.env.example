# ═══════════════════════════════════════
# IGNITE TECHFEST 2026 — SERVER ENV VARS
# ═══════════════════════════════════════

NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ignite-techfest-2026

# JWT (Legacy - replaced by Clerk)
JWT_SECRET=replace_with_strong_random_secret_min_64_chars
JWT_EXPIRES_IN=7d

# Clerk
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Email (Gmail App Password)
EMAIL_USER=ignite.techfest@iilm.edu
EMAIL_PASS=your_gmail_app_password_here

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# Firebase Admin SDK
FIREBASE_PROJECT_ID=ignite-techfest-2026
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@ignite-techfest-2026.iam.gserviceaccount.com

# CORS
CLIENT_URL=http://localhost:5173

# Admin
ADMIN_EMAIL=admin@iilm.edu
